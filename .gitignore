# Service runtime trees (protected by encrypted backup, not Git)
# App shelf: APK binaries are reproducible via app-shelf/fetch-seed-apks.sh;
# user-added APKs (e.g. owned games) and Filebrowser state are runtime, not Git.
app-shelf/apks/*.apk
app-shelf/filebrowser/
Home_Media/*
!Home_Media/compose.yml
!Home_Media/.env.example
HomeAssistant/hadata/.storage/
HomeAssistant/hadata/.HA_VERSION
HomeAssistant/hadata/backups/
HomeAssistant/hadata/deps/
HomeAssistant/hadata/tts/
HomeAssistant/hadata-bak/
n8n/data/
# Zigbee2MQTT runtime/state: the live configuration.yaml holds the generated
# network_key and pan_id; database.db/state.json/coordinator_backup are runtime.
zigbee/zigbee2mqtt/data/
zigbee/mosquitto/config/passwd
seerr/config/
# Windows focus agent local config holds the broker password (in Bitwarden).
windows-focus-agent/config.ini
# discover-dnd.ps1 output: machine-specific registry dumps, diagnostic only
windows-focus-agent/dnd-*.txt
plex/PMS/
plex/PMS-small/
Home_Media.tgz
traefik/letsencrypt/
**/.structurizr/
# Structurizr Lite renders this from workspace.dsl; the JSON is generated runtime state.
structurizr-lite/workspace/workspace.json

# Captured HTTP request fragments and editor/OS noise
traefik/GET
traefik/Host:
traefik/accept:
traefik/user-agent:
.DS_Store
Thumbs.db
*~

# Local backup credentials and scratch data
.local/
ops/backup/*.password
ops/backup/*.password-file
ops/backup/backup.env
ops/backup/restore/
ops/backup/tmp/
