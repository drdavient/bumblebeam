# Copy to backup.env, then chmod 600 backup.env and the password files.
ELEMENTS_MOUNT=/mnt/Elements
ELEMENTS_UUID=72908AD6908A9FE9
LOCAL_REPOSITORY=/mnt/Elements/Backups/Bumblebeam/restic
LOCAL_PASSWORD_FILE=/home/drdavient/.config/restic/bumblebeam-local.password

# Dave-OneDrive is temporary. Never use rclone sync/copy/move against this path.
REMOTE_REPOSITORY=rclone:Dave-OneDrive:Backups/Bumblebeam/restic
REMOTE_PASSWORD_FILE=/home/drdavient/.config/restic/bumblebeam-onedrive.password

# Optional n8n-compatible failure webhook. Leave empty to log only.
ALERT_URL=
LOCAL_USAGE_WARN_PERCENT=85
MAX_SNAPSHOT_AGE_HOURS=36
